{
  "expo": {
    "name": "SharkRank",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060B18"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sharkrank.app",
      "infoPlist": {
        "NSCameraUsageDescription": "O SharkRank precisa da câmera para gravar replays das suas melhores jogadas.",
        "NSMicrophoneUsageDescription": "O SharkRank precisa do microfone para capturar o áudio ambiente da partida."
      }
    },
    "android": {
      "package": "com.sharkrank.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060B18"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SharkRank to access your camera",
          "microphonePermission": "Allow SharkRank to access your microphone",
          "recordAudioAndroid": true
        }
      ],
      "expo-media-library"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
